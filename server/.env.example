PORT=5000
CLIENT_ORIGIN=http://localhost:5173
APIFY_TOKEN=
APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
APIFY_TIKTOK_PROFILE_ACTOR=clockworks/tiktok-profile-scraper
APIFY_TIKTOK_TRENDS_ACTOR=clockworks/tiktok-trends-scraper
APIFY_TIKTOK_TOP_ADS_ACTOR=beyondops/tiktok-ad-library-scraper
TIKTOK_TOP_ADS_LIMIT=48
TIKTOK_TOP_ADS_MEMORY_MB=2048
TIKTOK_TOP_ADS_CACHE_TTL_HOURS=12
TIKTOK_TOP_ADS_CACHE_MIN_ITEMS=5
# Set to 1 to log first raw Apify dataset row (keys + truncated JSON) on each refresh
# TIKTOK_TOP_ADS_DEBUG_LOG=
TIKTOK_TRENDING_MUSIC_DEFAULT_COUNTRY=US
TIKTOK_TRENDING_MUSIC_LIMIT=48
TIKTOK_TRENDING_MUSIC_INTERVAL_MS=86400000
TIKTOK_TRENDING_MUSIC_DAILY_COUNTRIES=US
# Facebook Ad Library (default: curious_coder/facebook-ads-library-scraper)
# APIFY_FACEBOOK_ADS_ACTOR=username/other-actor-id
# Set to 1 for EU reach / extra fields (costs more Apify usage)
# Set to 1 to log a second raw Apify dataset item (verbose)
# APIFY_DEBUG_LOGS=

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_ANALYSIS_MODEL=claude-3-5-haiku-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
